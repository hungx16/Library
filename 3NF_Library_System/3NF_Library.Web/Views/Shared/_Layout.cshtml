<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <head>
        <title>@ViewData["Title"] - 3NF Library</title>
        <link rel="icon" type="image/png" href="@Url.Content("~/images/logo.png")" />
    </head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-dark text-white">
    @* Giữ giao diện tối như ảnh image_509044.png *@
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-black border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="Logo" style="height:100px;">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-book"></i> Home (Sách)</a>
                        </li>

                        @* HIỂN THỊ MENU RIÊNG CHO ADMIN KHI ĐÃ ĐĂNG NHẬP *@
                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="Home" asp-action="AdminDashboard">Dashboard Admin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Home" asp-action="ActivityLogs">Nhật ký</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="AddLibrarian">Thêm thủ thư</a>
                            </li>
                        }

                        @* MENU DÀNH CHO THỦ THƯ (LIBRARIAN) *@
                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Librarian"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold" asp-controller="Home" asp-action="LibrarianDashboard">
                                    <i class="bi bi-clipboard-check"></i> Dashboard Thủ thư
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold" asp-controller="Home" asp-action="ManageFines">
                                    <i class="bi bi-exclamation-triangle-fill"></i> Vi phạm
                                </a>
                            </li>
                            <li class="nav-item">                                 
                                <a class="nav-link text-success fw-bold" asp-controller="Home" asp-action="AddReader">
                                    <i class="bi bi-person-plus"></i> Đăng ký khách
                                </a>
                            </li>
                        }
                    </ul>

                    @* CỤM NÚT ĐĂNG NHẬP / ĐĂNG XUẤT (GÓC PHẢI) *@
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light border-end me-2">Chào, <b>@User.Identity.Name</b></span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-danger btn-sm" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            @* NÚT ĐĂNG NHẬP SẼ HIỆN Ở ĐÂY KHI CHƯA CÓ AI LOGIN *@
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary text-white btn-sm px-4" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Thông báo SuccessMessage giữ nguyên từ bản trước *@
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            alert('@Html.Raw(TempData["SuccessMessage"]?.ToString()?.Replace("\n", "\\n") ?? "")');
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            alert('❌ LỖI: @Html.Raw(TempData["ErrorMessage"]?.ToString()?.Replace("\n", "\\n") ?? "")');
        </script>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>