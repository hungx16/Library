@model List<_3NF_Library.Models.Entities.vw_Book_Public>
@{
    ViewData["Title"] = "Quản lý Kho Sách";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-journal-bookmark-fill"></i> QUẢN LÝ KHO SÁCH</h2>
        <div>
            <button class="btn btn-success shadow-sm me-2" data-bs-toggle="modal" data-bs-target="#addBookModal"><i class="bi bi-plus-lg"></i> Thêm Sách</button>
            <button class="btn btn-outline-info shadow-sm" data-bs-toggle="modal" data-bs-target="#categoryModal"><i class="bi bi-tags"></i> Phân loại</button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="card shadow bg-dark text-white border-secondary">
                <div class="card-header bg-secondary fw-bold text-center">TÌM KIẾM NHANH</div>
                <div class="card-body p-3">
                    <form method="get">
                        <div class="mb-3">
                            <label class="small opacity-75">Từ khóa</label>
                            <input type="text" name="search" class="form-control bg-secondary text-white border-0" value="@Context.Request.Query["search"]">
                        </div>
                        <div class="mb-3">
                            <label class="small opacity-75">Thể loại</label>
                            <select name="categoryId" class="form-select bg-secondary text-white border-0">
                                <option value="">-- Tất cả --</option>
                                @foreach (var cat in ViewBag.CategoryStats)
                                {
                                    <option value="@cat.CategoryID">@cat.CategoryName</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 shadow-sm">Áp dụng lọc</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="table-responsive shadow rounded">
                <table class="table table-dark table-hover border-secondary align-middle mb-0">
                    <thead class="table-primary text-dark">
                        <tr>
                            <th>Mã sách</th>
                            <th>Tên sách</th>
                            <th>Tác giả</th>
                            <th>Sẵn có</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var book in Model)
                        {
                            <tr>
                                <td class="text-info small"><code>@book.BookID</code></td>
                                <td class="fw-bold">@book.BookTitle</td>
                                <td class="small">@book.AuthorName</td>
                                <td>
                                    <span class="badge @(book.CurrentlyAvailable > 0 ? "bg-success" : "bg-danger")">
                                        @book.CurrentlyAvailable cuốn
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-info"
                                            onclick="openEditBookModal('@book.BookID', '@book.BookTitle', '@book.CurrentlyAvailable')">
                                        <i class="bi bi-pencil-square"></i> Cập nhật
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editBookModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white border-info">
            <form asp-action="UpdateBook" method="post">
                <div class="modal-header border-info">
                    <h5 class="modal-title">Cập nhật kho sách</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-3">
                    <input type="hidden" name="bookId" id="edit-book-id" />
                    <div class="mb-3">
                        <label class="small">Tên sách</label>
                        <input type="text" name="title" id="edit-book-title" class="form-control bg-secondary text-white border-0" required />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="small">Số lượng trong kho</label>
                            <input type="number" name="qty" id="edit-book-qty" class="form-control bg-secondary text-white border-0" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="small">Giá trị (VNĐ)</label>
                            <input type="number" name="val" id="edit-book-val" class="form-control bg-secondary text-white border-0" required value="50000" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-info">
                    <button type="submit" class="btn btn-info w-100 shadow-sm">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addBookModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-dark text-white border-success">
            <form asp-action="AddBook" method="post">
                <div class="modal-header border-success">
                    <h5 class="modal-title font-italic">Thêm sách mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="small fw-bold">Tựa sách</label>
                        <input type="text" name="title" class="form-control bg-secondary text-white border-0" required />
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold">Ngôn ngữ</label>
                        <input type="text" name="lang" class="form-control bg-secondary text-white border-0" value="Tiếng Việt" required />
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="small fw-bold">Phân Loại</label>
                            <div class="input-group">
                                <select name="catId" class="form-select bg-secondary text-white border-0" required>
                                    <option value="">--- Chọn Thể Loại ---</option>
                                    @foreach (var c in ViewBag.CategoryStats)
                                    {
                                        <option value="@c.CategoryID">@c.CategoryName</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-light px-4" data-bs-toggle="modal" data-bs-target="#quickCategoryModal">Thêm nhanh</button>
                            </div>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label class="small fw-bold">Tác giả</label>
                            <div class="input-group">
                                <select name="authorId" class="form-select bg-secondary text-white border-0" required>
                                    <option value="">--- Chọn Tác Giả ---</option>
                                    @foreach (var a in ViewBag.Authors)
                                    {
                                        <option value="@a.AuthorID">@a.LastName @a.FirstName</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-light px-4" data-bs-toggle="modal" data-bs-target="#quickAuthorModal">Thêm nhanh</button>
                            </div>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label class="small fw-bold">Nhà xuất bản</label>
                            <div class="input-group">
                                <select name="pubId" class="form-select bg-secondary text-white border-0" required>
                                    <option value="">--- Chọn Nhà Xuất Bản ---</option>
                                    @foreach (var p in ViewBag.Publishers)
                                    {
                                        <option value="@p.PublisherID">Nhà xuất bản: @p.Description</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-light px-4" data-bs-toggle="modal" data-bs-target="#quickPublisherModal">Thêm nhanh</button>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="small fw-bold">Ngày xuất bản</label>
                            <input type="date" name="pubDate" class="form-control bg-secondary text-white border-0" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="small fw-bold">Số lượng</label>
                            <input type="number" name="qty" class="form-control bg-secondary text-white border-0" required min="1" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="small fw-bold">Giá</label>
                            <input type="number" name="val" class="form-control bg-secondary text-white border-0" required min="0" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-success d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Quay về</button>
                    <button type="submit" class="btn btn-primary px-5 shadow-sm">Thêm sách</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="quickCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-light text-dark shadow-lg">
            <form asp-action="QuickAddCategory" method="post">
                <div class="modal-body p-4">
                    <h5 class="font-italic mb-4" style="border-bottom: 1px solid #ccc; padding-bottom: 10px;">Thêm phân loại sách</h5>
                    <div class="row mb-3 align-items-center">
                        <div class="col-4"><label class="small">Tên phân loại</label></div>
                        <div class="col-8"><input type="text" name="name" class="form-control border-secondary" required /></div>
                    </div>
                    <div class="row mb-4 align-items-center">
                        <div class="col-4"><label class="small">Tên ngắn</label></div>
                        <div class="col-8"><input type="text" name="shortName" class="form-control border-secondary" /></div>
                    </div>
                    <div class="text-center"><button type="submit" class="btn btn-light border-secondary shadow-sm px-4">Thêm phân loại</button></div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="quickAuthorModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-light text-dark shadow-lg">
            <form asp-action="QuickAddAuthor" method="post">
                <div class="modal-body p-4">
                    <h5 class="font-italic mb-4" style="border-bottom: 1px solid #ccc; padding-bottom: 10px;">Thêm tác giả</h5>
                    <div class="row mb-2 align-items-center"><div class="col-3"><label class="small">Họ:</label></div><div class="col-9"><input type="text" name="lastName" class="form-control border-secondary" required /></div></div>
                    <div class="row mb-2 align-items-center"><div class="col-3"><label class="small">Tên:</label></div><div class="col-9"><input type="text" name="firstName" class="form-control border-secondary" required /></div></div>
                    <div class="row mb-2 align-items-center"><div class="col-3"><label class="small">Ngày sinh:</label></div><div class="col-9"><input type="date" name="dob" class="form-control border-secondary" /></div></div>
                    <div class="row mb-2 align-items-center"><div class="col-3"><label class="small">Chuyên môn:</label></div><div class="col-9"><input type="text" name="specialty" class="form-control border-secondary" /></div></div>
                    <div class="row mb-4"><div class="col-3"><label class="small">Mô tả:</label></div><div class="col-9"><textarea name="description" class="form-control border-secondary" rows="3"></textarea></div></div>
                    <div class="text-end"><button type="submit" class="btn btn-light border-secondary shadow-sm px-4">Thêm</button></div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="quickPublisherModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-light text-dark shadow-lg">
            <form asp-action="QuickAddPublisher" method="post">
                <div class="modal-body p-4">
                    <h5 class="font-italic mb-4" style="border-bottom: 1px solid #ccc; padding-bottom: 10px;">Thêm nhà xuất bản</h5>
                    <div class="row mb-3 align-items-center">
                        <div class="col-4"><label class="small">Tên nhà xuất bản</label></div>
                        <div class="col-8"><input type="text" name="name" class="form-control border-secondary" required /></div>
                    </div>
                    <div class="row mb-4 align-items-center">
                        <div class="col-4"><label class="small">Địa chỉ (thành phố, quốc gia)</label></div>
                        <div class="col-8"><input type="text" name="address" class="form-control border-secondary" /></div>
                    </div>
                    <div class="text-center"><button type="submit" class="btn btn-light border-secondary shadow-sm px-4">Thêm</button></div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. Hàm dùng để mở Modal Edit Sách (Giữ nguyên của bạn)
        function openEditBookModal(id, title, qty) {
            document.getElementById('edit-book-id').value = id;
            document.getElementById('edit-book-title').value = title;
            document.getElementById('edit-book-qty').value = qty;
            new bootstrap.Modal(document.getElementById('editBookModal')).show();
        }

        // ================= CỤM XỬ LÝ AJAX THÊM NHANH ================= //

        // 2. Xử lý Thêm Thể Loại
        $('#quickCategoryModal form').submit(function (e) {
            e.preventDefault(); // Chặn load lại trang
            $.post($(this).attr('action'), $(this).serialize(), function (res) {
                if (res.success) {
                    var newOption = new Option(res.text, res.id, true, true);
                    $('select[name="catId"]').append(newOption).trigger('change');
                    $('#quickCategoryModal').modal('hide'); // Đóng form nhỏ
                    $('#quickCategoryModal form')[0].reset(); // Xóa dữ liệu vừa nhập
                    alert('✅ Đã thêm Thể loại thành công!');
                } else { alert('❌ Lỗi: ' + res.message); }
            });
        });

        // 3. Xử lý Thêm Tác Giả
        $('#quickAuthorModal form').submit(function (e) {
            e.preventDefault();
            $.post($(this).attr('action'), $(this).serialize(), function (res) {
                if (res.success) {
                    var newOption = new Option(res.text, res.id, true, true);
                    $('select[name="authorId"]').append(newOption).trigger('change');
                    $('#quickAuthorModal').modal('hide');
                    $('#quickAuthorModal form')[0].reset();
                    alert('✅ Đã thêm Tác giả thành công!');
                } else { alert('❌ Lỗi: ' + res.message); }
            });
        });

        // 4. Xử lý Thêm Nhà Xuất Bản
        $('#quickPublisherModal form').submit(function (e) {
            e.preventDefault();
            $.post($(this).attr('action'), $(this).serialize(), function (res) {
                if (res.success) {
                    var newOption = new Option("NXB: " + res.text, res.id, true, true);
                    $('select[name="pubId"]').append(newOption).trigger('change');
                    $('#quickPublisherModal').modal('hide');
                    $('#quickPublisherModal form')[0].reset();
                    alert('✅ Đã thêm Nhà xuất bản thành công!');
                } else { alert('❌ Lỗi: ' + res.message); }
            });
        });
    </script>
}