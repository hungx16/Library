@{
    ViewData["Title"] = "Giao dịch Mượn - Trả";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm bg-dark text-white border-primary">
                <div class="card-header bg-primary fw-bold"><i class="bi bi-plus-circle"></i> Tạo Đơn Mượn Mới</div>
                <div class="card-body p-3">
                    <form asp-action="CreateBorrowOrder" method="post">
                        <div class="mb-3">
                            <label class="small fw-bold">Chọn Độc giả</label>
                            <select name="readerId" class="form-select bg-secondary text-white border-0" required>
                                <option value="">-- Tìm tên/ID --</option>
                                @foreach (var r in ViewBag.Readers)
                                {
                                    <option value="@r.ReaderID">DG@(r.ReaderID.ToString("D5")) - @r.LastName @r.FirstName</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="small fw-bold">Mã sách (cách nhau dấu phẩy)</label>
                            <input type="text" name="bookIds" class="form-control" placeholder="KA00001, VH00002..." required />
                        </div>
                        <div class="mb-3">
                            <label class="small fw-bold">Ngày hẹn trả</label>
                            <input type="date" name="returnDate" class="form-control" value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-dd")" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 shadow-sm mt-2">Ghi nhận đơn chờ</button>
                    </form>
                </div>
            </div>
        </div>

        @* ... Các phần trước giữ nguyên ... *@

        <div class="col-md-4">
            <h5 class="text-warning fw-bold mb-3"><i class="bi bi-hourglass-split"></i> Đơn Chờ Duyệt</h5>
            <div class="table-responsive shadow-sm rounded">
                <table class="table table-dark table-sm border-secondary align-middle">
                    <thead class="table-warning text-dark">
                        <tr><th>Mã</th><th>Độc giả</th><th>Sách</th><th class="text-center">Duyệt / X</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in ViewBag.PendingOrders)
                        {
                            <tr>
                                <td>#@p.OrderID</td>
                                <td class="small">@p.ReaderName</td>
                                <td class="small">@p.BookList</td>
                                <td class="text-center d-flex justify-content-center gap-2">
                                    <form asp-action="ApproveOrder" method="post">
                                        <input type="hidden" name="orderId" value="@p.OrderID" />
                                        <button class="btn btn-warning btn-sm py-0 px-2" title="Duyệt mượn"><i class="bi bi-check-lg"></i></button>
                                    </form>
                                    <form asp-action="RejectOrder" method="post" onsubmit="return confirm('Bạn có chắc muốn từ chối và xóa đơn này?')">
                                        <input type="hidden" name="orderId" value="@p.OrderID" />
                                        <button type="submit" class="btn btn-danger btn-sm py-0 px-2" title="Hủy đơn"><i class="bi bi-x-lg"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* ... Cột 3 giữ nguyên ... *@

        <div class="col-md-5">
            <h5 class="text-success fw-bold mb-3"><i class="bi bi-journal-check"></i> Đơn Đang Mượn</h5>
            <div class="table-responsive shadow-sm rounded">
                <table class="table table-dark table-sm border-secondary align-middle">
                    <thead class="table-success text-dark">
                        <tr><th>Mã</th><th>Độc giả</th><th>Hạn trả</th><th class="text-center">Thao tác</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var b in ViewBag.BorrowingOrders)
                        {
                            <tr>
                                <td>#@b.OrderID</td>
                                <td class="small fw-bold">@b.ReaderName</td>
                                <td class="small">@b.Deadline</td>
                                <td class="text-center">
                                    @* NẾU ĐƠN ĐÃ TRẢ THÌ HIỆN CHỮ, CHƯA TRẢ THÌ HIỆN NÚT *@
                                    @if (b.Status == "Returned")
                                    {
                                        <span class="badge bg-secondary opacity-75"><i class="bi bi-check-all"></i> Đã trả</span>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-center gap-1">
                                            <form asp-action="ConfirmReturn" method="post" class="d-inline">
                                                <input type="hidden" name="orderId" value="@b.OrderID" />
                                                <button type="submit" class="btn btn-outline-success btn-sm py-0 px-2" onclick="return confirm('Xác nhận khách đã trả đủ sách?')">
                                                    Trả sách
                                                </button>
                                            </form>

                                            <button type="button" class="btn btn-danger btn-sm py-0 px-2 shadow-sm" onclick="openLostBookModal(@b.OrderID, '@b.ReaderName')">
                                                Báo mất
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="lostBookModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white border-danger shadow-lg">
            <form asp-action="ProcessLostBooks" method="post">
                <div class="modal-header border-danger">
                    <h5 class="modal-title text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Báo Mất Sách</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" name="orderId" id="lost-order-id" />

                    <div class="mb-3">
                        <label class="small opacity-75">Độc giả:</label>
                        <div id="lost-reader-name" class="fw-bold text-warning fs-5"></div>
                    </div>

                    <div class="mb-3">
                        <label class="small opacity-75 mb-2">Chọn những cuốn sách bị mất (Sẽ tự động bị trừ khỏi kho):</label>
                        <div id="lost-books-container" class="bg-secondary p-3 rounded border border-secondary shadow-sm">
                        </div>
                    </div>

                    <div class="alert alert-warning small py-2 mb-0 shadow-sm border-0">
                        <i class="bi bi-info-circle-fill"></i> Hệ thống sẽ tự động đối chiếu chức vụ của độc giả để tính toán <strong>% giảm giá tiền phạt</strong>.
                    </div>
                </div>
                <div class="modal-footer border-danger d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger px-4 shadow-sm" onclick="return confirm('Xác nhận báo mất các cuốn sách đã chọn?\nHành động này không thể hoàn tác!')">Xác nhận báo mất</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openLostBookModal(orderId, readerName) {
            // Điền thông tin cơ bản vào form
            $('#lost-order-id').val(orderId);
            $('#lost-reader-name').text(readerName);

            // Hiện icon loading trong lúc chờ dữ liệu
            $('#lost-books-container').html('<div class="text-center text-light"><div class="spinner-border spinner-border-sm"></div> Đang tải danh sách...</div>');

            // Gọi AJAX lấy sách
            $.get('/Home/GetBooksForOrder', { orderId: orderId }, function (data) {
                var html = '';
                if (data.length === 0) {
                    html = '<div class="text-success small"><i class="bi bi-check-circle"></i> Đơn này không còn sách nào đang mượn.</div>';
                } else {
                    // Tạo ra list checkbox cho từng cuốn sách
                    data.forEach(function (book) {
                        html += `
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="lostBooks" value="${book.id}" id="chk_${book.id}">
                            <label class="form-check-label text-light fw-bold ms-2" style="cursor:pointer;" for="chk_${book.id}">
                                <code class="text-info">${book.id}</code> - ${book.title}
                            </label>
                        </div>`;
                    });
                }
                $('#lost-books-container').html(html);

                // Mở Modal
                new bootstrap.Modal(document.getElementById('lostBookModal')).show();
            }).fail(function() {
                $('#lost-books-container').html('<div class="text-danger small">Lỗi tải dữ liệu. Vui lòng thử lại!</div>');
            });
        }
    </script>
}