@model List<_3NF_Library.Models.Entities.vw_Book_Public>
@{
    ViewData["Title"] = "Danh mục sách thư viện";
}

<div class="container mt-4">
    @* HIỂN THỊ TIN BÁO THÀNH CÔNG NỔI BẬT TẠI ĐÂY *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-start border-5 border-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <h2 class="text-center mb-4 text-primary fw-bold">Tủ Sách Hệ Thống</h2>

    <div class="table-responsive shadow-sm">
        <table class="table table-dark table-hover table-striped border border-secondary">
            <thead class="table-dark">
                <tr>
                    <th>Mã sách</th>
                    <th>Tên sách</th>
                    <th>Tác giả</th>
                    <th>Thể loại</th>
                    <th>Nhà xuất bản</th>
                    <th class="text-center">Tình trạng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td>@book.BookID</td>
                        <td class="fw-bold">@book.BookTitle</td>
                        <td>@book.AuthorName</td>
                        <td>@book.CategoryName</td>
                        <td>@((book.PublisherName) ?? String.Empty)</td>
                        <td class="text-center">
                            @if (book.CurrentlyAvailable > 0)
                            {
                                <span class="badge bg-success">Còn @book.CurrentlyAvailable cuốn</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Hết sách</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>